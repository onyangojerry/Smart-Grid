EA_ENV=development
EA_API_HOST=0.0.0.0
EA_API_PORT=8000
EA_JWT_SECRET=replace-with-strong-32-plus-byte-secret
EA_JWT_ALGORITHM=HS256
EA_JWT_EXP_MIN=120
EA_ALLOW_WEAK_JWT_SECRET=false
EA_ENABLE_DEV_AUTH=false
EA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EA_SERVICE_KEYS=ops-key:svc_ops:ops_admin:,ml-key:svc_ml:ml_engineer:
EA_STORE_BACKEND=postgres
EA_STORE_REQUIRED=true
EA_HOLDOUT_MAPE_RETRAIN_THRESHOLD=0.08
EA_COMMAND_MAX_RETRIES=3
EA_PENDING_ACK_BLOCK_SECONDS=30

EA_DB_HOST=postgres
EA_DB_PORT=5432
EA_DB_NAME=energyallocation
EA_DB_USER=energyallocation
EA_DB_PASSWORD=energyallocation
EA_DB_SCHEMA=public
EA_DATABASE_URL=postgresql://energyallocation:energyallocation@postgres:5432/energyallocation

EDGE_RUNTIME_MODE=service
EDGE_SITE_ID=site_001
EDGE_GATEWAY_ID=gw_edge_01
EDGE_DEVICE_PROFILE=simulated_home_bess
EDGE_PROFILE_REGISTER_MAP_PATH=
EDGE_DEVICE_ENABLED=true
EDGE_READ_ONLY_MODE=false
EDGE_OBSERVATION_ONLY_MODE=false
EDGE_SQLITE_PATH=./data/edge/edge_runtime.db
EDGE_STATUS_FILE=./data/edge/status.json
EA_API_BASE_URL=http://localhost:8000
# Auth precedence: EDGE_API_KEY (X-API-Key) is primary; bearer is used only when EDGE_API_KEY is empty.
EDGE_API_BEARER_TOKEN=
EDGE_API_KEY=ops-key
EDGE_MODBUS_HOST=127.0.0.1
EDGE_MODBUS_PORT=15020
# Strict by default: runtime uses profile default unit ID.
# If EDGE_MODBUS_UNIT_ID differs from profile default, startup fails unless EDGE_ALLOW_PROFILE_UNIT_ID_OVERRIDE=true.
EDGE_MODBUS_UNIT_ID=
EDGE_ALLOW_PROFILE_UNIT_ID_OVERRIDE=false
EDGE_MODBUS_TIMEOUT_SECONDS=3.0
EDGE_POLL_INTERVAL_SECONDS=5
EDGE_COMMAND_INTERVAL_SECONDS=5
EDGE_STATUS_INTERVAL_SECONDS=10
EDGE_REPLAY_LIMIT=500
EDGE_REPLAY_BASE_BACKOFF_SECONDS=2
EDGE_REPLAY_MAX_BACKOFF_SECONDS=60
EDGE_SHUTDOWN_GRACE_SECONDS=10
EDGE_CONTINUE_ON_POLL_ERROR=true

EDGE_SIM_MODBUS_HOST=0.0.0.0
EDGE_SIM_MODBUS_PORT=15020
